    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "tailwindcss": "^4",
    "trigger.dev": "^4.4.6",
    "tsx": "^4.20.7",
    "typescript": "^5"
